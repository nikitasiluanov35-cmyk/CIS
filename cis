def _get_ids(session, register_id: str) -> list[str]:
    iteration_id = _PKG_CACHE.get(register_id, {}).get("CurrentIterationId", "")
    if not iteration_id:
        try:
            r = _get(session, f"{BACKEND2}/Register/{register_id}", timeout=20)
            if r.status_code == 200:
                iteration_id = r.json().get("CurrentIterationId", "")
        except Exception:
            pass

    if iteration_id:
        try:
            r = _get(session,
                     f"{BACKEND2}/RegisterIteration/getRegisterDynamicDocuments/{iteration_id}",
                     timeout=60)
            if r.status_code == 200:
                data = r.json()
                if isinstance(data, list) and data:
                    ids = [item.get("DynamicDocumentItem", {}).get("DynamicDocumentId", "")
                           for item in data]
                    ids = [i for i in ids if i and len(i) == 36]
                    if ids:
                        log.info("  ID получены: %d", len(ids))
                        return ids
        except Exception as e:
            log.debug("  %s", e)

    for url in [f"{BACKEND}/DynamicDocument/getByFilter",
                f"{BACKEND}/RegisterDynamicDocumentSet/getByFilter"]:
        all_ids, page = [], 1
        while True:
            try:
                r = _post(session, url,
                          json={"RegisterId": register_id, "PageNumber": page, "PageSize": _BATCH},
                          timeout=30)
                if r.status_code != 200:
                    break
                data  = r.json()
                items = _extract_items(data)
                if not items:
                    break
                all_ids.extend(
                    str(i.get("Id") or i.get("id") or "")
                    for i in items if i.get("Id") or i.get("id")
                )
                total = int(data.get("TotalItems") or data.get("totalItems") or 0)
                log.info("  ID: %d%s", len(all_ids), f"/{total}" if total else "")
                if (total and len(all_ids) >= total) or len(items) < _BATCH:
                    break
                page += 1
            except Exception:
                break
        if all_ids:
            return all_ids
    return []


def _fetch_details_parallel(session, ids: list[str]) -> list[dict]:
    """
    Загружает детали документов параллельно батчами по _BATCH.
    Использует пул потоков для одновременных запросов.
    """
    url     = f"{BACKEND}/DynamicDocument/GetDocumentShortListItemsByIds"
    token   = session.headers.get("Authorization", "")
    batches = [ids[i:i + _BATCH] for i in range(0, len(ids), _BATCH)]

    results: list[dict] = [None] * len(batches)  # type: ignore

    def fetch_batch(idx: int, batch: list[str]) -> tuple[int, list[dict]]:
        s = _make_session()
        s.headers["Authorization"] = token
        try:
            r = s.post(url, json=batch, timeout=30)
            if r.status_code == 200:
                data = r.json()
                return idx, [_normalize(x)
                              for x in (data if isinstance(data, list)
                                        else (data.get("Items") or []))]
        except Exception as e:
            log.debug("  батч %d: %s", idx, e)
        return idx, []

    workers = min(len(batches), WORKERS)
    with ThreadPoolExecutor(max_workers=workers) as pool:
        futures = {pool.submit(fetch_batch, i, b): i for i, b in enumerate(batches)}
        for future in as_completed(futures):
            try:
                idx, batch_result = future.result()
                results[idx] = batch_result
            except Exception:
                results[futures[future]] = []

    return [doc for batch in results if batch for doc in batch]


def _get_or_load_docs(session, reg_id: str) -> list[dict]:
    if reg_id in _DOCS_CACHE:
        return _DOCS_CACHE[reg_id]
    with _DOCS_LOCK:
        if reg_id not in _DOCS_CACHE:
            log.info("  Загружаю документы реестра (параллельно)...")
            ids  = _get_ids(session, reg_id)
            docs = _fetch_details_parallel(session, ids) if ids else []
            # Индекс по номеру для O(1) поиска
            _DOCS_CACHE[reg_id] = docs
            log.info("  Документов: %d", len(docs))
        return _DOCS_CACHE[reg_id]


