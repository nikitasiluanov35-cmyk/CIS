    def _check_update() -> None:
        if not GITHUB_RAW_URL:
            return
        try:
            import urllib.request
            import re as _re

            print(f"  Версия: {VERSION}  Проверяю обновления...")
            with urllib.request.urlopen(GITHUB_RAW_URL, timeout=5) as resp:
                remote = resp.read().decode("utf-8")

            # Читаем версию из удалённого файла
            m = _re.search(r'^VERSION\s*=\s*["\'](.+?)["\']', remote, _re.M)
            if not m:
                return
            remote_ver = m.group(1)

            if remote_ver == VERSION:
                print(f"  Версия актуальна ({VERSION})")
                return

            print(f"  Доступна новая версия: {remote_ver}  (у вас: {VERSION})")
            ans = input("  Обновить? [Enter = да / n = нет]: ").strip().lower()
            if ans == "n":
                return

            # Сохраняем текущий файл как резервную копию
            import os
            script = os.path.abspath(__file__)
            backup = script + f".bak_{VERSION}"
            with open(script, "rb") as f:
                with open(backup, "wb") as b:
                    b.write(f.read())

            # Записываем новую версию
            with open(script, "w", encoding="utf-8") as f:
                f.write(remote)

            print(f"  ✓ Обновлено до версии {remote_ver}")
            print(f"  Резервная копия: {backup}")
            print(f"  Перезапустите скрипт.")
            sys.exit(0)

        except Exception as e:
            print(f"  Не удалось проверить обновления: {e}")

    _check_update()
    main()

