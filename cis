def _upload_hdrs(session) -> dict:
    return {k: v for k, v in session.headers.items() if k.lower() != "content-type"}

def replace_file(session, doc: dict, new_file: Path) -> tuple[bool, str]:
    """Заменяет файл у существующего документа."""
    short_id = doc.get("Id", "")
    if not short_id:
        return False, "Нет Id документа"

    # _get_full_doc нужен — как в рабочей версии
    full    = _get_full_doc(session, short_id)
    real_id = (full or {}).get("Id") or short_id
    url     = f"{BACKEND}/DynamicDocument/Upload"
    hdrs    = _upload_hdrs(session)

    for attempt in range(2):
        try:
            with open(new_file, "rb") as fh:
                r = requests.post(
                    url,
                    params={"id": real_id},
                    files={"File": (new_file.name, fh, _mime(new_file))},
                    headers=hdrs, verify=False, timeout=120,
                )
            if r.status_code == 401 and attempt == 0 and _reauth(session, r):
                hdrs = _upload_hdrs(session)
                continue
            if r.status_code in (200, 201, 204):
                log.info("  ✓ Файл заменён [%d]", r.status_code)
                return True, f"Файл: {new_file.name}"
            log.error("  Upload %d: %s", r.status_code, r.text[:200])
            return False, f"Upload ошибка {r.status_code}"
        except Exception as e:
            return False, f"Exception: {e}"
    return False, "Не удалось загрузить"


