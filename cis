                    results_map[item["number"]] = res

                log.info("  Добавляю в реестр по порядку...")
                ts_main = _get_thread_session()
                for item in items:
                    res    = results_map.get(item["number"],
                             {"number": item["number"], "status": "✗ Ошибка",
