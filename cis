# ─────────────────────────────────────────────────────────────
_DATE_FORMATS = ("%d.%m.%Y", "%Y-%m-%d", "%d/%m/%Y", "%d.%m.%y")
_EXCEL_EPOCH  = datetime.datetime(1899, 12, 30)

def _parse_date(value) -> Optional[int]:
    if value is None:
        return None
    if isinstance(value, datetime.datetime):
        return int(value.timestamp() * 1000)
    if isinstance(value, datetime.date):
        return int(datetime.datetime(value.year, value.month, value.day).timestamp() * 1000)
    if isinstance(value, (int, float)):
        if value > 1_000_000_000_000:
            return int(value)
        try:
            return int((_EXCEL_EPOCH + datetime.timedelta(days=float(value))).timestamp() * 1000)
        except Exception:
            return None
    s = str(value).strip()
    for fmt in _DATE_FORMATS:
        try:
            return int(datetime.datetime.strptime(s, fmt).timestamp() * 1000)
        except ValueError:
            continue
    return None


def read_doc_list() -> list[dict]:
    p = Path(CIS_DATA_FILE)
    if not p.exists():
        log.error("Файл не найден: %s", CIS_DATA_FILE)
        sys.exit(1)
    wb = openpyxl.load_workbook(p, read_only=True, data_only=True)
    ws = next(
        (wb[n] for n in wb.sheetnames if "докум" in n.lower() or "document" in n.lower()),
        wb.active,
    )
    hdrs = [str(c.value).strip() if c.value else ""
            for c in next(ws.iter_rows(min_row=2, max_row=2))]
    if DOC_COLUMN not in hdrs:
        log.error("Колонка «%s» не найдена. Есть: %s", DOC_COLUMN, [h for h in hdrs if h])
        sys.exit(1)
    ci_num  = hdrs.index(DOC_COLUMN)
    ci_date = next((hdrs.index(c) for c in ("Дата", "Date", "дата") if c in hdrs), None)
    items = [
        {"number": num,
         "date_ms": _parse_date(row[ci_date]) if ci_date is not None else None,
         "fp": None}
        for row in ws.iter_rows(min_row=3, values_only=True)
        if (num := (str(row[ci_num]).strip() if row[ci_num] is not None else ""))
        and num.lower() != "none"
    ]
    wb.close()
    log.info("  Загружено %d документов из «%s»", len(items), ws.title)
    return items


# ─────────────────────────────────────────────────────────────
#  СЕССИЯ С CONNECTION POOL И RETRY
# ─────────────────────────────────────────────────────────────
def _make_session(pool_size: int = 10) -> requests.Session:
    """
    Создаёт сессию с:
      - увеличенным connection pool (не пересоздаём соединения)
      - авто-retry на сетевые ошибки (не на 4xx/5xx)
    """
    s = requests.Session()
    s.verify = False

    retry = Retry(
        total=3,
        backoff_factor=0.3,
        status_forcelist=(),       # не ретраим по статусу — только сетевые ошибки
        allowed_methods=["GET", "POST", "PUT", "DELETE"],
    )
    adapter = HTTPAdapter(
        max_retries=retry,
        pool_connections=pool_size,
        pool_maxsize=pool_size,
    )
    s.mount("https://", adapter)
    s.mount("http://",  adapter)

    s.headers.update({
        "User-Agent":   "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/124.0",
        "Accept":       "application/json, text/plain, */*",
        "Content-Type": "application/json",
    })
    return s


# ─────────────────────────────────────────────────────────────
#  АВТОРИЗАЦИЯ
# ─────────────────────────────────────────────────────────────
def _save_token(token: str) -> None:
    try:
        p = Path(TOKEN_FILE)
        p.parent.mkdir(parents=True, exist_ok=True)
        p.write_text(json.dumps({"token": token}), encoding="utf-8")
    except Exception as e:
        log.warning("  Токен не сохранён: %s", e)

def _load_token() -> Optional[str]:
    try:
        p = Path(TOKEN_FILE)
        if p.exists():
            return json.loads(p.read_text(encoding="utf-8")).get("token")
    except Exception:
        pass
    return None

def _check_token(session: requests.Session) -> bool:
    try:
        return session.get(f"{BACKEND2}/WorkType", timeout=8).status_code != 401
    except Exception:
        return False

def _do_login(session: requests.Session) -> bool:
    try:
        r = session.post(AUTH_URL, json={"login": USERNAME, "password": PASSWORD}, timeout=15)
        if r.status_code == 200:
            token = r.json().get("token")
            if token:
                session.headers["Authorization"] = f"Bearer {token}"
                _save_token(token)
                return True
            log.error("Токен не получен: %s", r.text[:150])
        elif r.status_code == 401:
            log.error("Неверный логин или пароль")
        else:
            log.error("Авторизация %d: %s", r.status_code, r.text[:150])
    except Exception as e:
        log.error("Сеть: %s", e)
    return False

def authorize() -> requests.Session:
    # Главная сессия — pool_size берём с запасом (WORKERS может быть ещё 0)
    s = _make_session(pool_size=max(WORKERS + 2, 18))
    saved = _load_token()
    if saved:
        s.headers["Authorization"] = f"Bearer {saved}"
        log.info("  Проверяю сохранённый токен...")
        if _check_token(s):
            log.info("✓ Авторизован по токену")
            return s
        log.info("  Токен устарел, логинюсь...")
    log.info("  Авторизация → %s", AUTH_URL)
    if _do_login(s):
        log.info("✓ Авторизован")
        return s
    log.error("✗ Авторизация не удалась")
    sys.exit(1)

def _reauth(session: requests.Session, r: requests.Response) -> bool:
    if r.status_code != 401:
        return False
    log.warning("  401 — обновляю токен...")
    try:
        Path(TOKEN_FILE).unlink(missing_ok=True)
    except Exception:
        pass
    return _do_login(session)


# ─────────────────────────────────────────────────────────────
#  HTTP ОБЁРТКИ
# ─────────────────────────────────────────────────────────────
def _request(method: str, session: requests.Session, url: str, **kw) -> requests.Response:
    fn = getattr(session, method)
    r  = fn(url, **kw)
    if r.status_code == 401 and _reauth(session, r):
        r = fn(url, **kw)
    return r

def _post(s, url, **kw):   return _request("post",   s, url, **kw)
def _get(s, url, **kw):    return _request("get",    s, url, **kw)


# ─────────────────────────────────────────────────────────────
#  АВТООПРЕДЕЛЕНИЕ ЧИСЛА ПОТОКОВ
# ─────────────────────────────────────────────────────────────
def auto_workers(session: requests.Session,
                 schema_id: str = "",
                 drawing_package_id: str = "") -> int:
    """
    Определяет оптимальное число потоков реальным тестом загрузки файлов.

    Использует реальные файлы из FILES_FOLDER — тест учитывает реальный вес PDF.
    Если файлов нет — fallback на минимальный PDF.
    Созданные тестовые документы удаляются после теста.
    """
    import time as _time
    from concurrent.futures import ThreadPoolExecutor as _TPE

    token = session.headers.get("Authorization", "")

    _schema_id = schema_id or next(iter(_SCHEMA_CACHE.values()), "")
    _pkg_id    = drawing_package_id
    use_upload = bool(_schema_id and _pkg_id)

    # Берём реальные файлы из папки — читаем несколько в память
    _test_files: list[tuple[str, bytes, str]] = []  # (filename, bytes, mime)
    if use_upload:
        folder = Path(FILES_FOLDER)
        if folder.exists():
            real_files = sorted(
                f for f in folder.iterdir()
                if f.is_file() and f.suffix.lower() in _MIME_MAP
            )[:10]  # берём до 10 файлов для ротации
            for fp in real_files:
                try:
                    _test_files.append((fp.name, fp.read_bytes(), _mime(fp)))
                except Exception:
                    pass

    if _test_files:
        total_size = sum(len(b) for _, b, _ in _test_files)
        avg_size   = total_size // len(_test_files)
        log.info("  Тест: реальные файлы из папки (%d шт., средний размер %d KB)",
                 len(_test_files), avg_size // 1024)
    elif use_upload:
        # Fallback — минимальный PDF
        _MINI_PDF = (
            b"%PDF-1.4\n1 0 obj<</Type/Catalog/Pages 2 0 R>>endobj\n"
            b"2 0 obj<</Type/Pages/Kids[3 0 R]/Count 1>>endobj\n"
            b"3 0 obj<</Type/Page/MediaBox[0 0 3 3]>>endobj\n"
            b"xref\n0 4\n0000000000 65535 f\n"
            b"0000000009 00000 n\n0000000058 00000 n\n"
            b"0000000115 00000 n\n"
            b"trailer<</Size 4/Root 1 0 R>>\nstartxref\n190\n%%EOF"
        )
        _test_files = [("test.pdf", _MINI_PDF, "application/pdf")]
        log.info("  Тест: файлов в папке нет, используется минимальный PDF")
    else:
        log.info("  Тест: GET-запросы (schema/pkg не известны)")

    created_ids: list[str] = []
    ids_lock = threading.Lock()

    def _upload_one(idx: int) -> float:
        """Отправляет один тестовый документ. Возвращает время (сек) или -1 при ошибке."""
        s = _make_session(pool_size=2)
        s.headers["Authorization"] = token

        if use_upload:
            # Ротируем файлы чтобы каждый поток брал разный
            fname, fbytes, fmime = _test_files[idx % len(_test_files)]
            number  = f"CIS-TEST-{idx:05d}"
            now_ms  = int(_time.time() * 1000)
            doc_meta = json.dumps({
                "Data": {"Дата документа": now_ms, "Номер документа": number},
                "Number": number,
                "SchemaId": _schema_id,
                "WorkTypes": [], "AltitudeMarks": [], "CoordinateAxis": [],
                "RelatedFieldItems": [],
                "Date": now_ms, "FileDescId": None,
                "Organization": ORGANIZATION_DEFAULT,
                "DrawingPackageIds": [_pkg_id],
                "StartDate": None, "EndDate": None,
                "PageCount": 1, "PageFormat": 4,
            }, ensure_ascii=False)
            hdrs = {k: v for k, v in s.headers.items()
                    if k.lower() not in ("content-type", "accept")}
            hdrs["Accept"] = "application/json, text/plain, */*"
            t0 = _time.perf_counter()
            try:
                r = s.post(
                    f"{BACKEND}/DynamicDocument",
                    headers=hdrs,
                    files={
                        "Document": (None, doc_meta, "application/json"),
                        "File":     (fname, fbytes, fmime),
                    },
                    verify=False, timeout=60,
                )
                elapsed = _time.perf_counter() - t0
                if r.status_code in (200, 201):
                    doc_id = r.json().get("Id") or r.json().get("id")
                    if doc_id:
                        with ids_lock:
                            created_ids.append(doc_id)
                    return elapsed
                if r.status_code in (429, 503, 502):
                    return -1.0
                return elapsed
            except Exception:
                return -1.0
        else:
            t0 = _time.perf_counter()
            try:
                r = s.get(f"{BACKEND2}/WorkType", timeout=15)
                elapsed = _time.perf_counter() - t0
                return -1.0 if r.status_code in (429, 503, 502) else elapsed
            except Exception:
                return -1.0

    def _delete_docs(ids: list[str]) -> None:
        """Удаляет тестовые документы чтобы не засорять реестр."""
        if not ids:
            return
        s = _make_session(pool_size=4)
        s.headers["Authorization"] = token
        for doc_id in ids:
            try:
                s.delete(f"{BACKEND}/DynamicDocument/{doc_id}",
                         verify=False, timeout=10)
            except Exception:
                pass

    def _bench(n: int) -> tuple[float, float, bool]:
        """Запускает n параллельных запросов. Возвращает (avg_lat, rps, ok)."""
        t_start = _time.perf_counter()
        with _TPE(max_workers=n) as pool:
            times = list(pool.map(_upload_one, range(n)))
        total_time = _time.perf_counter() - t_start

        good = [t for t in times if t > 0]
        errors = len([t for t in times if t < 0])
        avg_lat = sum(good) / len(good) if good else 99.0
        rps     = len(good) / total_time if total_time > 0 else 0
        ok      = errors <= n * 0.1  # допускаем до 10% ошибок
        return avg_lat, rps, ok

    log.info("  Ступенчатый тест пропускной способности...")

    # Базовый замер — 1 запрос
    base_lat, _, _ = _bench(1)
    log.info("  Базовая латентность: %.2fс", base_lat)

    best_workers = 1
    best_rps     = 0.0
    steps        = list(range(1, 129))   # шаг 1: от 1 до 128
    no_gain      = 0                     # сколько шагов подряд RPS не растёт
    PATIENCE     = 5                     # останавливаемся после 5 шагов без роста

    for n in steps:
        avg_lat, rps, ok = _bench(n)
        degradation = avg_lat / base_lat if base_lat > 0 else 1.0

        status = ""
        if not ok:               status = "  ✗ ошибки сервера"
        elif degradation > 8.0:  status = f"  ⚠ деградация ×{degradation:.1f}"

        log.info("  %3d потоков: %.2fс | %.0f загр/с%s", n, avg_lat, rps, status)

        if not ok:
            log.info("  Сервер даёт ошибки при %d потоках — стоп", n)
            break

        if degradation > 15.0:
            log.info("  Критическая деградация ×%.1f — стоп", degradation)
            break

        if rps > best_rps * 1.03:   # рост хотя бы на 3%
            best_rps     = rps
            best_workers = n
            no_gain      = 0
        else:
            no_gain += 1
            if no_gain >= PATIENCE:
                log.info("  RPS не растёт %d шагов подряд — оптимум найден", PATIENCE)
                break

    # Удаляем все тестовые документы
    if created_ids:
        log.info("  Удаляю %d тестовых документов...", len(created_ids))
        _delete_docs(created_ids)

    log.info("  ✓ Оптимум: %d потоков (%.0f загр/с)", best_workers, best_rps)
    return best_workers



def _normalize(d: dict) -> dict:
    return {k[0].upper() + k[1:]: v for k, v in d.items()}

def _doc_number(doc: dict) -> str:
    return str(doc.get("Number") or doc.get("Name") or "")

def _extract_items(data) -> list:
    if isinstance(data, list):
        return data
    return data.get("Items") or data.get("items") or data.get("data") or []


