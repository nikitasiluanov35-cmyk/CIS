def create_document(
    session,
    number: str,
    schema_id: str,
    drawing_package_id: str,
    file_path: Path,
    date_ms: Optional[int] = None,
) -> tuple[bool, str]:
    if date_ms is None:
        date_ms = int(datetime.datetime.now().timestamp() * 1000)

    organization = resolve_org(number)
    log.info("  Создаю «%s»  Орг: %s  Дата: %s",
             number, organization,
             datetime.datetime.fromtimestamp(date_ms / 1000).strftime("%d.%m.%Y"))

    doc_meta = {
        "Data":              {"Дата документа": date_ms, "Номер документа": number},
        "Number":            number,
        "SchemaId":          schema_id,
        "WorkTypes":         [],
        "AltitudeMarks":     [],
        "CoordinateAxis":    [],
        "RelatedFieldItems": [],
        "Date":              date_ms,
        "FileDescId":        None,
        "Organization":      organization,
        "DrawingPackageIds": [drawing_package_id],
        "StartDate":         None,
        "EndDate":           None,
        "PageCount":         1,
        "PageFormat":        4,
    }

    hdrs = {k: v for k, v in session.headers.items()
            if k.lower() not in ("content-type", "accept")}
    hdrs["Accept"] = "application/json, text/plain, */*"

    doc_meta_str = json.dumps(doc_meta, ensure_ascii=False)

    for attempt in range(2):
        try:
            # Открываем файл заново при каждой попытке (как в рабочей версии)
            with open(file_path, "rb") as fh:
                r = requests.post(
                    f"{BACKEND}/DynamicDocument",
                    headers=hdrs,
                    files={
                        "Document": (None, doc_meta_str, "application/json"),
                        "File":     (file_path.name, fh, _mime(file_path)),
                    },
                    verify=False, timeout=120,
                )
            if r.status_code == 401 and attempt == 0 and _reauth(session, r):
                hdrs["Authorization"] = session.headers.get("Authorization", "")
                continue
            if r.status_code in (200, 201):
                doc_id = r.json().get("Id") or r.json().get("id")
                if doc_id:
                    log.info("  ✓ Создан Id=%s", doc_id)
                    return True, doc_id
                return False, "Ответ без Id"
            log.error("  Create %d: %s", r.status_code, r.text[:400])
            if r.status_code == 400:
                log.error("  Отправлено: SchemaId=%s  Org=%s  DrawingPkg=%s",
                          doc_meta.get("SchemaId","")[:8],
                          doc_meta.get("Organization",""),
                          (doc_meta.get("DrawingPackageIds") or [""])[0][:8])
            return False, f"Ошибка {r.status_code}: {r.text[:200]}"
        except Exception as e:
            return False, f"Exception: {e}"
    return False, "Не удалось создать"


def add_to_register(session, register_id: str, doc_id: str) -> bool:
    r = _post(session,
              f"{BACKEND2}/Register/AddDynamicDocuments/{register_id}",
              json={"documentIds": [doc_id], "copyDocumentIds": []},
              timeout=20)
    if r.status_code in (200, 201, 204):
