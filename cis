    # Прогрев кэша схем ПОСЛЕ получения списка — знаем все уникальные типы
    if is_create:
        log.info("  Загружаю схемы документов (один раз для всех потоков)...")
        # Сбрасываем resolve-кэш — он мог заполниться в _preview до load_mappings
        _schema_resolve_cache.clear()
