            else:
                # ── БЕЗ СОРТИРОВКИ ──────────────────────────────────────
                # Полностью параллельно: создание + add_to_register в одном потоке
                log.info("  Режим: без сортировки (максимальная скорость)")
                for future in as_completed(futures):
                    item = futures[future]
                    try:
                        res = future.result()
                    except Exception as e:
                        res = {"number": item["number"], "status": "✗ Ошибка",
                               "details": str(e), "doc_id": None}

                    doc_id = res.get("doc_id")
