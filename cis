# ─────────────────────────────────────────────────────────────
#  MIME (кэшируем результат для каждого расширения)
# ─────────────────────────────────────────────────────────────
_MIME_MAP: dict[str, str] = {
    ".pdf":  "application/pdf",
    ".dwg":  "application/acad",
    ".dxf":  "application/dxf",
    ".doc":  "application/msword",
    ".docx": "application/vnd.openxmlformats-officedocument.wordprocessingml.document",
    ".xls":  "application/vnd.ms-excel",
    ".xlsx": "application/vnd.openxmlformats-officedocument.spreadsheetml.sheet",
    ".png":  "image/png",
    ".jpg":  "image/jpeg",
    ".jpeg": "image/jpeg",
    ".tif":  "image/tiff",
    ".tiff": "image/tiff",
}
_mime_cache: dict[str, str] = {}

def _mime(fp: Path) -> str:
    ext = fp.suffix.lower()
    if ext not in _mime_cache:
        m, _ = mimetypes.guess_type(fp.name)
        _mime_cache[ext] = m or _MIME_MAP.get(ext, "application/octet-stream")
    return _mime_cache[ext]


