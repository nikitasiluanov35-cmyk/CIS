def get_items(source: int) -> list[dict]:
    """Получает список документов согласно выбранному источнику."""
    print()

    if source == 1:
        print(f"  Читаю лист «Документы» из: {CIS_DATA_FILE}")
        items = read_doc_list()
        if not items:
            print("  Список пуст.")
            sys.exit(1)
        # Добавляем порядковый индекс
        for i, item in enumerate(items):
            item["_order"] = i
        print(f"  Загружено: {len(items)} строк")
        _preview(items)
        print()
        if input("  Продолжить? [Enter = да / n = нет]: ").strip().lower() == "n":
            sys.exit(0)
        return items

    if source == 2:
        current = FILES_FOLDER
        print(f"  Текущая папка: {current}")
        new_p = input("  Enter = использовать, или введите другой путь: ").strip()
        if new_p:
            current = new_p
        folder = Path(current)
        if not folder.exists():
            print(f"  ОШИБКА: папка не найдена: {current}")
            sys.exit(1)
        all_files = sorted(f for f in folder.iterdir() if f.is_file())
        files     = [f for f in all_files if f.suffix.lower() in _VALID_EXT]
        skipped   = len(all_files) - len(files)
        if skipped:
            print(f"  Пропущено (неизвестное расширение): {skipped}")
        if not files:
            print("  Нет файлов с поддерживаемыми расширениями.")
            sys.exit(1)
        items = [{"number": fp.stem, "date_ms": None, "fp": fp, "_order": i}
                 for i, fp in enumerate(files)]
        print(f"  Файлов для обработки: {len(files)}")
        _preview(items)
        print()
        if input("  Продолжить? [Enter = да / n = нет]: ").strip().lower() == "n":
            sys.exit(0)
        return items

    # source == 3: вручную
    number = input("  Введите номер документа: ").strip()
    if not number:
        print("  Номер не введён.")
        sys.exit(0)
    return [{"number": number, "date_ms": None, "fp": None, "_order": 0}]


def _preview(items: list[dict], n: int = 3) -> None:
    print("  Примеры (номер | дата | схема | организация):")
    for it in items[:n]:
        number = it["number"]
        d_str  = (datetime.datetime.fromtimestamp(it["date_ms"] / 1000).strftime("%d.%m.%Y")
                  if it.get("date_ms") else "текущая")
        sch    = resolve_schema(number) or "⚠ нет маппинга"
        sch    = sch[:40] + "…" if len(sch) > 40 else sch
        print(f"    {number}  |  {d_str}  |  {sch}  |  {resolve_org(number)}")
    if len(items) > n:
        print(f"    ... и ещё {len(items) - n}")


