def save_report(rows: list[dict], operation: str,
                start_time: datetime.datetime, reg_code: int = 0) -> None:
    if not rows:
        return
    p = Path(CIS_DATA_FILE)
    if not p.exists():
        log.error("Отчёт не сохранён: %s", CIS_DATA_FILE)
        return
    try:
        wb = openpyxl.load_workbook(p)
    except Exception as e:
        log.error("Не удалось открыть файл: %s", e)
        return

    report_name = next(
        (n for n in wb.sheetnames if "отч" in n.lower() or "report" in n.lower()), None
    )
    if report_name:
        ws = wb[report_name]
        ws.delete_rows(1, ws.max_row)
    else:
        ws = wb.create_sheet("Отчёт")

    # Строка 1
    ws.merge_cells("A1:D1")
    ws["A1"] = (f"Операция: {operation}  |  Реестр: {reg_code}  |  "
                f"Дата: {datetime.datetime.now().strftime('%d.%m.%Y %H:%M:%S')}")
    ws["A1"].fill = _NOTE_F; ws["A1"].font = _NOTE_T
    ws["A1"].alignment = _VCENTER
    ws.row_dimensions[1].height = 20

    # Строка 2 — заголовки
    headers = ["Номер документа", "Статус", "Подробности", "Время"]
    widths  = [30, 18, 55, 12]
    for col, (h, w) in enumerate(zip(headers, widths), 1):
        cell = ws.cell(row=2, column=col, value=h)
        cell.fill = _H_FILL; cell.font = _H_FONT; cell.alignment = _CENTER
        ws.column_dimensions[get_column_letter(col)].width = w
    ws.row_dimensions[2].height = 20

    # Данные — используем предаллоцированные объекты стилей
    for ri, row in enumerate(rows, 3):
        fill = _STATUS_FILLS.get(row["Статус"]) or (_ALT_F if ri % 2 == 0 else _NO_FILL)
        for col, h in enumerate(headers, 1):
            cell = ws.cell(row=ri, column=col, value=row[h])
            cell.fill = fill; cell.alignment = _VCENTER
        ws.row_dimensions[ri].height = 16

    ok   = sum(1 for r in rows if r["Статус"] == "✓ Успешно")
    fail = sum(1 for r in rows if "✗" in r["Статус"])
    skip = sum(1 for r in rows if r["Статус"] == "— Пропущен")
    sr   = ws.max_row + 2
    ws.cell(row=sr, column=1, value="ИТОГО").font = _BOLD
    ws.cell(row=sr, column=2,
            value=f"✓ {ok}  ✗ {fail}  — {skip}  |  "
                  f"{str(datetime.datetime.now() - start_time).split('.')[0]}").font = _BOLD
    ws.freeze_panes = "A3"

    try:
        wb.save(p)
        log.info("✓ Отчёт → «%s»: %s", ws.title, CIS_DATA_FILE)
    except Exception as e:
        log.error("Не удалось сохранить отчёт: %s", e)


