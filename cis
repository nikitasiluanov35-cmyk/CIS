    # source == 3: вручную
    number = input("  Введите номер документа: ").strip()
    if not number:
        print("  Номер не введён.")
        sys.exit(0)
    return [{"number": number, "date_ms": None, "fp": None, "_order": 0}]


def _preview(items: list[dict], n: int = 3) -> None:
    print("  Примеры (номер | дата | схема | организация):")
    for it in items[:n]:
        number = it["number"]
        d_str  = (datetime.datetime.fromtimestamp(it["date_ms"] / 1000).strftime("%d.%m.%Y")
                  if it.get("date_ms") else "текущая")
        sch    = resolve_schema(number) or "⚠ нет маппинга"
        sch    = sch[:40] + "…" if len(sch) > 40 else sch
        print(f"    {number}  |  {d_str}  |  {sch}  |  {resolve_org(number)}")
    if len(items) > n:
        print(f"    ... и ещё {len(items) - n}")


