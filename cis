    drawing_pkg_id = None
    if is_create:
        log.info("Получаю DrawingPackageId...")
        drawing_pkg_id = get_drawing_package_id(session, reg_id)

    # Прогрев кэшей до старта потоков
    log.info("Подготовка...")
    if not is_create:
        _get_docs_index(session, reg_id)
    _get_files_index(FILES_FOLDER)

    items    = get_items(source)
    total    = len(items)
    rows: list[dict] = []
    ok = fail = skip = 0
    start_ts = datetime.datetime.now()

    # Прогрев кэша схем ПОСЛЕ получения списка — знаем все уникальные типы
    if is_create:
        log.info("  Загружаю схемы документов (один раз для всех потоков)...")
        # Сбрасываем resolve-кэш — он мог заполниться в _preview до load_mappings
        _schema_resolve_cache.clear()
        _org_resolve_cache.clear()

        # Проверяем какие номера не покрыты маппингом
        no_schema = [item["number"] for item in items if not resolve_schema(item["number"])]
        if no_schema:
            log.warning("  ⚠ Не найден маппинг схемы для %d документов:", len(no_schema))
            for n in no_schema[:10]:
                log.warning("    %s", n)
            if len(no_schema) > 10:
                log.warning("    ... и ещё %d", len(no_schema) - 10)
            log.warning("  Добавьте шаблоны в лист «Схемы» файла cis_data.xlsx")
            log.warning("  Документы без маппинга будут пропущены автоматически")
            # Оставляем только документы с найденной схемой
            items = [item for item in items if resolve_schema(item["number"])]
            total = len(items)
            log.info("  Будет обработано: %d документов", total)

        unique_titles = {resolve_schema(item["number"]) for item in items}
        log.info("  Уникальных типов схем: %d", len(unique_titles))
        for title in unique_titles:
            if title and title not in _SCHEMA_CACHE:
                get_schema_id(session, title)
        log.info("  ✓ Все схемы найдены и закэшированы")

    # Автоопределение числа потоков — ПОСЛЕ прогрева схем, чтобы передать schema_id
    global WORKERS
    if WORKERS == 0:
        log.info("Автоопределение числа потоков (реальный тест загрузки)...")
        # Берём первую найденную схему и drawing_package_id для теста
        _test_schema = next(iter(_SCHEMA_CACHE.values()), "")
        _test_pkg    = drawing_pkg_id or ""
        WORKERS = auto_workers(session, _test_schema, _test_pkg)
    else:
        log.info("Потоков (задано вручную): %d", WORKERS)

    log.info("=" * 60)
    log.info("Начинаю. %s | Реестр: %d | Документов: %d | Потоков: %d", oper_name, reg_code, total, WORKERS)
    log.info("=" * 60)

    token   = session.headers.get("Authorization", "").removeprefix("Bearer ")
    counter = [0]
    c_lock  = threading.Lock()

    # Создаём пул сессий заранее — по одной на поток, не пересоздаём на каждый документ
    _thread_sessions: dict[int, requests.Session] = {}
    _sess_lock = threading.Lock()

    def _get_thread_session() -> requests.Session:
        tid = threading.get_ident()
        if tid not in _thread_sessions:
            with _sess_lock:
                if tid not in _thread_sessions:
                    ts = _make_session(pool_size=8)
                    ts.headers["Authorization"] = f"Bearer {token}"
                    _thread_sessions[tid] = ts
        return _thread_sessions[tid]

    def process(item: dict) -> dict:
        number  = item["number"]
        fp      = item.get("fp")
        date_ms = item.get("date_ms")

        # Нормализуем номер: кириллица → латиница (NGS-VТ → NGS-VT)
        number = _norm_number(number)

        ts = _get_thread_session()   # переиспользуем сессию потока

        with c_lock:
            counter[0] += 1
            idx = counter[0]

        if not is_create:
            log.info("[%d/%d] Замена: %s", idx, total, number)
            if fp is None:
                fp = find_local_file(number)
            if not fp:
                return {"number": number, "status": "— Пропущен",
                        "details": "Файл не найден"}
            doc = find_doc_by_number(ts, reg_id, number)
            if not doc:
                log.error("  [%s] ✗ Не найден в реестре", number)
                return {"number": number, "status": "✗ Не найден",
                        "details": "Не найден в реестре"}
            ok_flag, details = replace_file(ts, doc, fp)
            if ok_flag:
                log.info("  [%s] ✓", number)
            else:
                log.error("  [%s] ✗ %s", number, details)
            return {"number": number,
                    "status": "✓ Успешно" if ok_flag else "✗ Ошибка",
                    "details": details}

        else:
            log.info("[%d/%d] Создание: %s", idx, total, number)
            if fp is None:
                fp = find_local_file(number)
            if not fp:
                return {"number": number, "status": "✗ Ошибка",
                        "details": "Файл не найден", "doc_id": None}
            schema_title = resolve_schema(number)
            if not schema_title:
                log.error("  [%s] ✗ Нет маппинга схемы — пропускаю", number)
                return {"number": number, "status": "— Пропущен",
                        "details": "Нет маппинга схемы в cis_data.xlsx", "doc_id": None}
            schema_id = get_schema_id(ts, schema_title)
            # Смещаем дату на index*1000мс — CIS сортирует по Date,
            # поэтому документы встанут в реестре в нужном порядке
            order_offset = item.get("_order", 0) * 1000
            ok_flag, result = create_document(
                ts, number, schema_id, drawing_pkg_id, fp,
                (date_ms or int(datetime.datetime.now().timestamp() * 1000)) + order_offset)
            if not ok_flag:
                return {"number": number, "status": "✗ Ошибка",
                        "details": result, "doc_id": None}
            doc_id = result
            log.info("  [%s] ✓ создан Id=%s", number, doc_id)

            if not keep_order:
                # Сразу добавляем в реестр прямо в потоке
                if add_to_register(ts, reg_id, doc_id):
                    fp_name = fp.name if fp else ""
                    return {"number": number, "status": "✓ Успешно",
                            "details": f"Id={doc_id}, файл={fp_name}", "doc_id": doc_id}
                return {"number": number, "status": "✗ Ошибка",
                        "details": f"Создан Id={doc_id}, не добавлен в реестр", "doc_id": doc_id}

            # С сортировкой — возвращаем doc_id, в реестр добавим позже по порядку
            return {"number": number, "status": "✓ Создан",
                    "details": f"файл={fp.name if fp else ''}", "doc_id": doc_id}

    # Параллельный запуск — создаём документы параллельно, но в реестр добавляем по порядку
    order          = {item["number"]: i for i, item in enumerate(items)}
    future_to_item = {}

    with ThreadPoolExecutor(max_workers=WORKERS) as pool:
        # Для замены — просто запускаем параллельно
        if not is_create:
            futures = {pool.submit(process, item): item["number"] for item in items}
            for future in as_completed(futures):
                try:
                    res = future.result()
                except Exception as e:
                    num = futures[future]
                    log.error("  [%s] необработанная ошибка: %s", num, e)
                    res = {"number": num, "status": "✗ Ошибка", "details": str(e)}
                rows.append({
                    "Номер документа": res["number"],
                    "Статус":          res["status"],
                    "Подробности":     res["details"],
                    "Время":           datetime.datetime.now().strftime("%H:%M:%S"),
                })
                s = res["status"]
                if s == "✓ Успешно":    ok   += 1
                elif s == "— Пропущен": skip += 1
                else:                   fail += 1
        else:
            futures = {pool.submit(process, item): item for item in items}

            if keep_order:
                # ── С СОРТИРОВКОЙ ───────────────────────────────────────
                # Создание параллельно, add_to_register строго по порядку
                log.info("  Режим: сохранение порядка (add_to_register последовательно)")
                results_map: dict[str, dict] = {}
                for future in as_completed(futures):
                    item = futures[future]
                    try:
                        res = future.result()
                    except Exception as e:
                        res = {"number": item["number"], "status": "✗ Ошибка",
                               "details": str(e), "doc_id": None}
                    results_map[item["number"]] = res

                log.info("  Добавляю в реестр по порядку...")
                ts_main = _get_thread_session()
                for item in items:
                    res    = results_map.get(item["number"],
                             {"number": item["number"], "status": "✗ Ошибка",
                              "details": "Нет результата", "doc_id": None})
                    doc_id = res.get("doc_id")
                    fp     = item.get("fp") or find_local_file(item["number"])

                    if res["status"] == "✓ Создан" and doc_id:
                        if add_to_register(ts_main, reg_id, doc_id):
                            log.info("  [%s] ✓ Id=%s", res["number"], doc_id)
                            res["status"]  = "✓ Успешно"
                            res["details"] = f"Id={doc_id}, файл={fp.name if fp else ''}"
                            ok += 1
                        else:
                            res["status"]  = "✗ Ошибка"
                            res["details"] = f"Создан Id={doc_id}, не добавлен в реестр"
                            fail += 1
                    elif res["status"] == "— Пропущен": skip += 1
                    elif res["status"] == "✓ Успешно":  ok   += 1
                    else:                                fail += 1

                    rows.append({
                        "Номер документа": res["number"],
                        "Статус":          res["status"],
                        "Подробности":     res.get("details", ""),
                        "Время":           datetime.datetime.now().strftime("%H:%M:%S"),
                    })

            else:
                # ── БЕЗ СОРТИРОВКИ ──────────────────────────────────────
                # Полностью параллельно: создание + add_to_register в одном потоке
                log.info("  Режим: без сортировки (максимальная скорость)")
                for future in as_completed(futures):
                    item = futures[future]
                    try:
                        res = future.result()
                    except Exception as e:
                        res = {"number": item["number"], "status": "✗ Ошибка",
                               "details": str(e), "doc_id": None}

                    doc_id = res.get("doc_id")
                    fp     = item.get("fp") or find_local_file(item["number"])

                    if res["status"] == "✓ Создан" and doc_id:
                        ts_main = _get_thread_session()
                        if add_to_register(ts_main, reg_id, doc_id):
                            log.info("  [%s] ✓ Id=%s", res["number"], doc_id)
                            res["status"]  = "✓ Успешно"
                            res["details"] = f"Id={doc_id}, файл={fp.name if fp else ''}"
                            ok += 1
                        else:
                            res["status"]  = "✗ Ошибка"
                            res["details"] = f"Создан Id={doc_id}, не добавлен в реестр"
                            fail += 1
                    elif res["status"] == "— Пропущен": skip += 1
                    elif res["status"] == "✓ Успешно":  ok   += 1
                    else:                                fail += 1

                    rows.append({
                        "Номер документа": res["number"],
                        "Статус":          res["status"],
                        "Подробности":     res.get("details", ""),
                        "Время":           datetime.datetime.now().strftime("%H:%M:%S"),
                    })

    elapsed = str(datetime.datetime.now() - start_ts).split(".")[0]
    log.info("=" * 60)
    log.info("Готово за %s.  ✓ %d   ✗ %d   — %d", elapsed, ok, fail, skip)
    log.info("=" * 60)

    save_report(rows, oper_name, start_ts, reg_code)


