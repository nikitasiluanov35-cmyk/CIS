_DATE_FORMATS = ("%d.%m.%Y", "%Y-%m-%d", "%d/%m/%Y", "%d.%m.%y")
_EXCEL_EPOCH  = datetime.datetime(1899, 12, 30)

def _parse_date(value) -> Optional[int]:
    if value is None:
        return None
    if isinstance(value, datetime.datetime):
        return int(value.timestamp() * 1000)
    if isinstance(value, datetime.date):
        return int(datetime.datetime(value.year, value.month, value.day).timestamp() * 1000)
    if isinstance(value, (int, float)):
        if value > 1_000_000_000_000:
            return int(value)
        try:
            return int((_EXCEL_EPOCH + datetime.timedelta(days=float(value))).timestamp() * 1000)
        except Exception:
            return None
    s = str(value).strip()
    for fmt in _DATE_FORMATS:
        try:
            return int(datetime.datetime.strptime(s, fmt).timestamp() * 1000)
        except ValueError:
            continue
    return None


def read_doc_list() -> list[dict]:
    p = Path(CIS_DATA_FILE)
    if not p.exists():
        log.error("Файл не найден: %s", CIS_DATA_FILE)
        sys.exit(1)
    wb = openpyxl.load_workbook(p, read_only=True, data_only=True)
    ws = next(
        (wb[n] for n in wb.sheetnames if "докум" in n.lower() or "document" in n.lower()),
        wb.active,
    )
    hdrs = [str(c.value).strip() if c.value else ""
            for c in next(ws.iter_rows(min_row=2, max_row=2))]
    if DOC_COLUMN not in hdrs:
        log.error("Колонка «%s» не найдена. Есть: %s", DOC_COLUMN, [h for h in hdrs if h])
        sys.exit(1)
    ci_num  = hdrs.index(DOC_COLUMN)
    ci_date = next((hdrs.index(c) for c in ("Дата", "Date", "дата") if c in hdrs), None)
    items = [
        {"number": num,
         "date_ms": _parse_date(row[ci_date]) if ci_date is not None else None,
         "fp": None}
        for row in ws.iter_rows(min_row=3, values_only=True)
        if (num := (str(row[ci_num]).strip() if row[ci_num] is not None else ""))
        and num.lower() != "none"
    ]
    wb.close()
    log.info("  Загружено %d документов из «%s»", len(items), ws.title)
    return items


# ─────────────────────────────────────────────────────────────
#  СЕССИЯ С CONNECTION POOL И RETRY
# ─────────────────────────────────────────────────────────────
def _make_session(pool_size: int = 10) -> requests.Session:
    """
    Создаёт сессию с:
      - увеличенным connection pool (не пересоздаём соединения)
      - авто-retry на сетевые ошибки (не на 4xx/5xx)
    """
    s = requests.Session()
    s.verify = False

    retry = Retry(
        total=3,
        backoff_factor=0.3,
        status_forcelist=(),       # не ретраим по статусу — только сетевые ошибки
        allowed_methods=["GET", "POST", "PUT", "DELETE"],
    )
    adapter = HTTPAdapter(
        max_retries=retry,
        pool_connections=pool_size,
        pool_maxsize=pool_size,
    )
    s.mount("https://", adapter)
    s.mount("http://",  adapter)

    s.headers.update({
        "User-Agent":   "Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/124.0",
        "Accept":       "application/json, text/plain, */*",
        "Content-Type": "application/json",
    })
    return s


