def find_register(session, code: int) -> dict:
    log.info("Ищу реестр %d...", code)
    for url, payload in [
        (f"{BACKEND2}/Register/getByFilter", {
            "Code": code, "PageNumber": 1, "PageSize": 25,
            "StatusId": [], "CustomerId": [], "ContractorId": [],
            "SubContractorId": [], "RespUserId": [], "MarkaIds": [],
            "TitleObjectIds": [], "DocumentCategoryId": [],
            "DocumentSubCategoryId": [], "OrderBy": "RegisterDate",
            "IsDesc": False, "ShowOnlyActive": False,
            "HideReviewedRegisters": False, "ShowOnlyWhereReviewRequired": False,
        }),
        (f"{BACKEND2}/Register/GetByFilter", {"Code": code, "PageNumber": 1, "PageSize": 25}),
        (f"{BACKEND}/Register/getByFilter",  {"Code": code, "PageNumber": 1, "PageSize": 1}),
    ]:
        try:
            r = _post(session, url, json=payload, timeout=20)
            if r.status_code == 200:
                items = _extract_items(r.json())
                if items:
                    reg = _normalize(items[0])
                    log.info("✓ Реестр: «%s»  Id=%s", reg.get("Name"), reg.get("Id"))
                    return reg
        except Exception as e:
            log.debug("  %s", e)
    log.error("Реестр %d не найден", code)
    sys.exit(1)


