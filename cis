_SCHEMA_CACHE: dict[str, str] = {}
_SCHEMA_LOCK  = threading.Lock()


def _paginate_schemas(session, payload: dict) -> list[dict]:
    result = []
    for skip in range(0, 1000, 20):
        try:
            r = session.post(
                f"{BACKEND}/DocumentSchema/getItems",
                json={**payload, "Skip": skip, "Top": 20},
                timeout=15,
            )
            if r.status_code != 200:
                break
            page = r.json() or []
            result.extend(page)
            if len(page) < 20:
                break
        except Exception:
            break
    return result


def _collect_all_schemas(session) -> list[dict]:
    """Параллельно загружает схемы по всем категориям."""
    all_schemas: dict[str, dict] = {}

    def _add(schemas: list) -> None:
        for s in schemas:
            sid = s.get("Id") or s.get("id")
            if sid and (s.get("Title") or s.get("title")):
                all_schemas[sid] = s

    # Получаем категории
    categories = []
    try:
        r = session.get(f"{BACKEND}/documentCategory", timeout=15)
        if r.status_code == 200:
            categories = r.json() if isinstance(r.json(), list) else []
            log.info("  Категорий: %d", len(categories))
    except Exception as e:
        log.debug("  documentCategory: %s", e)

    # Параллельно загружаем схемы по каждой категории
    def fetch_cat(cat):
        cat_id = cat.get("Id") or cat.get("id")
        if not cat_id:
            return []
        return _paginate_schemas(session, {"CategoryId": cat_id, "ShowOnlyActive": True})

    with ThreadPoolExecutor(max_workers=min(len(categories) or 1, 8)) as pool:
        for schemas in pool.map(fetch_cat, categories):
            _add(schemas)

    # Запасной: без категории
    _add(_paginate_schemas(session, {"ShowOnlyActive": True}))

    # GetGenerateDocumentSchemaIds
    try:
        r = session.get(f"{BACKEND}/DocumentSchema/GetGenerateDocumentSchemaIds", timeout=15)
        if r.status_code == 200:
            missing = [sid for sid in (r.json() or []) if sid not in all_schemas]

            def fetch_schema(sid):
                try:
                    r2 = session.get(f"{BACKEND}/DocumentSchema/{sid}", timeout=15)
                    if r2.status_code == 200:
                        return r2.json()
                except Exception:
                    pass
                return None

            with ThreadPoolExecutor(max_workers=8) as pool:
                for s in pool.map(fetch_schema, missing):
                    if s and s.get("Id") and (s.get("Title") or s.get("title")):
                        all_schemas[s["Id"]] = s
    except Exception:
        pass

    result = [s for s in all_schemas.values() if s.get("Title") or s.get("title")]
    log.info("  Схем найдено: %d", len(result))
    return result


def get_schema_id(session, title: str) -> str:
    """Потокобезопасный поиск SchemaId с кэшированием."""
    # Нормализуем ключ кэша
    title = title.replace("\xa0", " ").replace("\u00a0", " ").strip()

    if title in _SCHEMA_CACHE:
        return _SCHEMA_CACHE[title]

    with _SCHEMA_LOCK:
        if title in _SCHEMA_CACHE:   # double-check
            return _SCHEMA_CACHE[title]

        log.info("  Ищу схему: «%s»...", title[:60])
        all_schemas = _collect_all_schemas(session)

        # Нормализуем \xa0 (неразрывный пробел) с обеих сторон перед сравнением
        def _norm(t: str) -> str:
            return t.replace("\xa0", " ").replace("\u00a0", " ").strip().lower()

        title_lower = _norm(title)
        exact   = next((s for s in all_schemas
                        if _norm(s.get("Title") or "") == title_lower), None)
        partial = [s for s in all_schemas
                   if title_lower in _norm(s.get("Title") or "")]

        match = exact or (partial[0] if partial else None)
        if match:
            sid = match.get("Id") or match.get("id")
            _SCHEMA_CACHE[title] = sid
            if not exact and len(partial) > 1:
                log.warning("  Несколько совпадений, берём: «%s»", match.get("Title"))
            else:
                log.info("  ✓ Схема: «%s»", match.get("Title"))
            return sid

        log.error("✗ Схема «%s» не найдена. Доступные:", title)
        for s in sorted(all_schemas, key=lambda x: x.get("Title") or ""):
            if t := s.get("Title"):
                log.error("    «%s»", t)
        sys.exit(1)


