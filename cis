def _sheet_map(wb, keywords: list[str]) -> dict[str, str]:
    ws = next(
        (wb[n] for n in wb.sheetnames if any(k in n.lower() for k in keywords)), None
    )
    if not ws:
        return {}
    return {
        str(row[0]).strip(): str(row[1]).strip()
        for row in ws.iter_rows(min_row=3, values_only=True)
        if row[0] and len(row) > 1 and row[1]
        and str(row[0]).strip().lower() not in ("", "none")
        and str(row[1]).strip().lower() not in ("", "none")
    }


def load_mappings() -> None:
    global SCHEMA_MAP, ORG_MAP
    p = Path(CIS_DATA_FILE)
    if not p.exists():
        log.warning("  %s не найден — резервные маппинги", CIS_DATA_FILE)
        return
    try:
        wb = openpyxl.load_workbook(p, read_only=True, data_only=True)
        schemas = _sheet_map(wb, ["схем", "schema"])
        orgs    = _sheet_map(wb, ["орган", "org"])
        wb.close()
    except Exception as e:
        log.error("  Не удалось открыть %s: %s", CIS_DATA_FILE, e)
        return
    if schemas:
        SCHEMA_MAP = schemas
        log.info("  Схемы: %d шаблонов", len(SCHEMA_MAP))
    if orgs:
        ORG_MAP = orgs
        log.info("  Организации: %d шаблонов", len(ORG_MAP))
    # Сбрасываем кэши resolve — они могли заполниться до загрузки маппингов
    _schema_resolve_cache.clear()
    _org_resolve_cache.clear()


# Таблица замены кириллических букв которые визуально совпадают с латинскими.
# Встречаются в именах файлов когда набирают в русской раскладке.
_CYR_TO_LAT = str.maketrans(
    "АВСЕНКМОРТХаеорсух",
    "ABCEHKMOPTXaeorcyx",
)

def _norm_number(number: str) -> str:
    """Нормализует номер: кириллица → латиница, убирает лишние пробелы."""
    return number.translate(_CYR_TO_LAT).strip()


# Кэш resolved значений — не пересчитываем для одинаковых номеров
_schema_resolve_cache: dict[str, str] = {}
_org_resolve_cache: dict[str, str]    = {}

def resolve_schema(number: str) -> Optional[str]:
    """Возвращает название схемы по номеру или None если не найдено в маппинге."""
    if number not in _schema_resolve_cache:
        num = _norm_number(number).upper()
        found = next((v for k, v in SCHEMA_MAP.items() if k.upper() in num), None)
        _schema_resolve_cache[number] = found  # type: ignore
    return _schema_resolve_cache[number]

def resolve_org(number: str) -> str:
    if number not in _org_resolve_cache:
        num = _norm_number(number).upper()
        _org_resolve_cache[number] = next(
            (v for k, v in ORG_MAP.items() if k.upper() in num),
            ORGANIZATION_DEFAULT,
        )
    return _org_resolve_cache[number]


