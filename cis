                            res["status"]  = "✓ Успешно"
                            res["details"] = f"Id={doc_id}, файл={fp.name if fp else ''}"
                            ok += 1
                        else:
                            res["status"]  = "✗ Ошибка"
                            res["details"] = f"Создан Id={doc_id}, не добавлен в реестр"
                            fail += 1
                    elif res["status"] == "— Пропущен": skip += 1
                    elif res["status"] == "✓ Успешно":  ok   += 1
                    else:                                fail += 1

                    rows.append({
                        "Номер документа": res["number"],
                        "Статус":          res["status"],
                        "Подробности":     res.get("details", ""),
                        "Время":           datetime.datetime.now().strftime("%H:%M:%S"),
